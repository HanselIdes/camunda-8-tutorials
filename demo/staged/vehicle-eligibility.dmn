<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:modeler="http://camunda.org/schema/modeler/1.0"
             id="vehicleEligibilityDRD"
             name="Vehicle Eligibility"
             namespace="http://camunda.org/schema/1.0/dmn"
             modeler:executionPlatform="Camunda Cloud"
             modeler:executionPlatformVersion="8.8.0">
  <decision id="vehicleEligibility" name="Vehicle Eligibility">
    <decisionTable id="decisionTable_vehicleEligibility" hitPolicy="FIRST">
      <input id="input_year" label="Vehicle year">
        <inputExpression id="inputExpression_year" typeRef="integer">
          <text>year</text>
        </inputExpression>
      </input>
      <input id="input_vehicleType" label="Vehicle type">
        <inputExpression id="inputExpression_vehicleType" typeRef="string">
          <text>vehicleType</text>
        </inputExpression>
      </input>
      <output id="output_riskScore" label="Risk score" name="riskScore" typeRef="integer"/>
      <output id="output_eligible" label="Eligible" name="eligible" typeRef="boolean"/>
      <!-- Row 1: 2022 or newer, personal vehicle -->
      <rule id="rule_1">
        <inputEntry id="inputEntry_1_year">
          <text>>= 2022</text>
        </inputEntry>
        <inputEntry id="inputEntry_1_type">
          <text>"PASSENGER CAR","MOTORCYCLE","MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text>
        </inputEntry>
        <outputEntry id="outputEntry_1_risk">
          <text>5</text>
        </outputEntry>
        <outputEntry id="outputEntry_1_eligible">
          <text>true</text>
        </outputEntry>
      </rule>
      <!-- Row 2: 2022 or newer, other type -->
      <rule id="rule_2">
        <inputEntry id="inputEntry_2_year">
          <text>>= 2022</text>
        </inputEntry>
        <inputEntry id="inputEntry_2_type">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_2_risk">
          <text>30</text>
        </outputEntry>
        <outputEntry id="outputEntry_2_eligible">
          <text>true</text>
        </outputEntry>
      </rule>
      <!-- Row 3: 2018–2021, personal vehicle -->
      <rule id="rule_3">
        <inputEntry id="inputEntry_3_year">
          <text>[2018..2021]</text>
        </inputEntry>
        <inputEntry id="inputEntry_3_type">
          <text>"PASSENGER CAR","MOTORCYCLE","MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text>
        </inputEntry>
        <outputEntry id="outputEntry_3_risk">
          <text>15</text>
        </outputEntry>
        <outputEntry id="outputEntry_3_eligible">
          <text>true</text>
        </outputEntry>
      </rule>
      <!-- Row 4: 2018–2021, other type -->
      <rule id="rule_4">
        <inputEntry id="inputEntry_4_year">
          <text>[2018..2021]</text>
        </inputEntry>
        <inputEntry id="inputEntry_4_type">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_4_risk">
          <text>40</text>
        </outputEntry>
        <outputEntry id="outputEntry_4_eligible">
          <text>true</text>
        </outputEntry>
      </rule>
      <!-- Row 5: before 2018, personal vehicle -->
      <rule id="rule_5">
        <inputEntry id="inputEntry_5_year">
          <text>&lt; 2018</text>
        </inputEntry>
        <inputEntry id="inputEntry_5_type">
          <text>"PASSENGER CAR","MOTORCYCLE","MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text>
        </inputEntry>
        <outputEntry id="outputEntry_5_risk">
          <text>25</text>
        </outputEntry>
        <outputEntry id="outputEntry_5_eligible">
          <text>true</text>
        </outputEntry>
      </rule>
      <!-- Row 6: before 2018, other type — ineligible -->
      <rule id="rule_6">
        <inputEntry id="inputEntry_6_year">
          <text>&lt; 2018</text>
        </inputEntry>
        <inputEntry id="inputEntry_6_type">
          <text>-</text>
        </inputEntry>
        <outputEntry id="outputEntry_6_risk">
          <text>50</text>
        </outputEntry>
        <outputEntry id="outputEntry_6_eligible">
          <text>false</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
