{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - microservice completes and process ends",
      "description": "Starts the process, mocks the microservice job (type: orchestrate-something), and asserts the process completes.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "template-microservice-tutorial-18us19m" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Run_microservice" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "template-microservice-tutorial-18us19m" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ]
}
