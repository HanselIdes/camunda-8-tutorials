{
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.4.0",
  "exporter": {
    "name": "Camunda Web Modeler",
    "version": "8c03b57"
  },
  "schemaVersion": 16,
  "id": "manualQaForm",
  "components": [
    {
      "text": "This is an example of a user task for a manual QA test after deploying to the development stage and should be adapted to your individual use case.",
      "label": "Text view",
      "type": "text",
      "layout": {
        "row": "Row1",
        "columns": null
      },
      "id": "manualQaFormIntroduction"
    },
    {
      "label": "Separator",
      "type": "separator",
      "layout": {
        "row": "Row2",
        "columns": null
      },
      "id": "manualQaFormSeparator"
    },
    {
      "label": "QA successful",
      "type": "checkbox",
      "layout": {
        "row": "Row3",
        "columns": null
      },
      "id": "fieldQaSuccessfulCheck",
      "key": "qaSuccessfulCheck",
      "defaultValue": true
    }
  ],
  "type": "default"
}