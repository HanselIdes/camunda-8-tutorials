{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - BPMN file updated and deployed to all environments",
      "description": "CI/CD pipeline triggered. BPMN file found in folder. Milestone created. File content retrieved. No prior milestone (getLatestMilestone returns null). Branch created, file updated in repo, MR merged, deployed successfully to dev, stage, and prod.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "cicdGitlabBlueprint" },
          "variables": {
            "folder": { "metadata": { "name": "my-folder" } },
            "webModelerFolderId": "folder-123"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getWebModelerToken" },
          "variables": { "webModelerToken": "token-abc" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getFolderDetails" },
          "variables": {
            "folder": {
              "metadata": { "name": "my-folder" },
              "content": {
                "files": [
                  { "id": "file-123", "name": "my-process.bpmn", "type": "BPMN" }
                ]
              }
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createMilestone" },
          "variables": { "milestoneId": "milestone-001" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getFileContent" },
          "variables": { "content": "<bpmn:process/>" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getLatestMilestone" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createBranch" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "checkFileExists" },
          "variables": { "fileExists": true }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "updateRepositoryFile" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "openMergeRequest" },
          "variables": { "createdMergeRequest": { "id": "mr-001" } }
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "977b3fd3-9a57-4fb3-8a93-c81f48f99622",
          "correlationKey": "mr-001",
          "variables": {
            "mergeRequestWebhookPayload": {
              "object_attributes": { "action": "merge", "id": "mr-001" }
            }
          }
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "cbe375f3-ee90-483e-a3e0-803641904bb0",
          "correlationKey": "dev",
          "variables": {
            "devDeploymentWebhookPayload": {
              "deployedFolder": "my-folder",
              "status": "success"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createMilestoneForDevDeployment" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "manualQaTest" },
          "variables": {}
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "9a53a5e9-436b-43d7-b0fe-2e8f1575b5cd",
          "correlationKey": "stage",
          "variables": {
            "stageDeploymentWebhookPayload": {
              "deployedFolder": "my-folder",
              "status": "success"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createMilestoneForStageDeployment" },
          "variables": {}
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "66da4b0d-b541-4de4-9ad0-436f2fd7f2c5",
          "correlationKey": "prod",
          "variables": {
            "prodDeploymentWebhookPayload": {
              "deployedFolder": "my-folder",
              "status": "success"
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createMilestoneForProdDeployment" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "cicdGitlabBlueprint" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "MR closed - pipeline aborted before deployment",
      "description": "Pipeline runs through to MR creation. GitLab webhook fires with action=close (MR was closed without merging). Process ends at 'Merge request closed' without proceeding to deployment.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "cicdGitlabBlueprint" },
          "variables": {
            "folder": { "metadata": { "name": "my-folder" } },
            "webModelerFolderId": "folder-123"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getWebModelerToken" },
          "variables": { "webModelerToken": "token-abc" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getFolderDetails" },
          "variables": {
            "folder": {
              "metadata": { "name": "my-folder" },
              "content": {
                "files": [
                  { "id": "file-456", "name": "my-process.bpmn", "type": "BPMN" }
                ]
              }
            }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createMilestone" },
          "variables": { "milestoneId": "milestone-002" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getFileContent" },
          "variables": { "content": "<bpmn:process/>" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "getLatestMilestone" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "createBranch" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "checkFileExists" },
          "variables": { "fileExists": true }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "updateRepositoryFile" },
          "variables": {}
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "openMergeRequest" },
          "variables": { "createdMergeRequest": { "id": "mr-002" } }
        },
        {
          "type": "PUBLISH_MESSAGE",
          "name": "977b3fd3-9a57-4fb3-8a93-c81f48f99622",
          "correlationKey": "mr-002",
          "variables": {
            "mergeRequestWebhookPayload": {
              "object_attributes": { "action": "close", "id": "mr-002" }
            }
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "cicdGitlabBlueprint" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ],
  "_integrationTestNotes": "This process integrates with GitLab API (create branch, check file, update/create file, open merge request) and Camunda Web Modeler API (get token, get folder details, get file content, get/create milestones). Integration tests should: (1) use a real GitLab test repository; (2) use real Web Modeler API credentials; (3) verify the merge request is created with correct content; (4) verify milestones are created in Web Modeler; (5) verify successful deployment events trigger stage and prod deployment milestones. Key CPT patterns: openMergeRequest resultExpression sets createdMergeRequest (not mergeRequestId) — used as correlationKey for checkMergeRequestStatus webhook (977b3fd3..., correlationKey=createdMergeRequest.id). Deployment webhooks use static correlation keys (dev/stage/prod). manualQaTest is old-style userTask (no zeebe:userTask extension) — use COMPLETE_JOB. splitAdditionalTasks is a parallel gateway — must complete all 3 paths: optionalTests, optionalBusinessOwnerVerification, and the direct path (handled automatically). PUBLISH_MESSAGE variables must match the resultExpression output (e.g. devDeploymentWebhookPayload) not raw request.body. Note: getFolderDetails must return folder.content.files array with items having an 'id' field (not 'fileId') since getFileContent uses file.id in URL. splitIsDmn routes BPMN files to getLatestMilestone (default path) and DMN files to endNoDmnMilestoneComparison (skip). getFileContent sets 'content' variable (via resultExpression header), not a nested 'file' object. The multi-instance sub-process runs per file: parallel fork (createMilestone + getFileContent), then getLatestMilestone (for BPMN), then splitHasMilestone (null → no comparison link needed)."
}
