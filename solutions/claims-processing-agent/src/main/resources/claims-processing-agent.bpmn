<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="204af60" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.10.0">
  <bpmn:escalation id="Escalation_Claims" name="Claims Escalation" escalationCode="claims_escalation" />
  <bpmn:process id="CamundaInsurance_ClaimsProcessing" name="Claims Processing Agent" isExecutable="true">
    <bpmn:startEvent id="Start_ClaimForm" name="Claim submitted with documents">
      <bpmn:documentation>Customer submits: personal details (customerId, customerEmail, name), claim information (claimId, claimType, damageDescription, incidentDate), and supporting documents (photos, repair estimates, police reports) uploaded via the form.</bpmn:documentation>
      <bpmn:extensionElements>
        <zeebe:formDefinition formId="claim-submission-form" />
        <zeebe:properties>
          <zeebe:property name="camundaModeler:exampleOutputJson" value="{&#10;  &#34;customerName&#34;: &#34;Maria Kovacs&#34;,&#10;  &#34;customerId&#34;: &#34;CUST-4521&#34;,&#10;  &#34;customerEmail&#34;: &#34;maria.kovacs@email.com&#34;,&#10;  &#34;claimId&#34;: &#34;CLM-2025-0042&#34;,&#10;  &#34;claimType&#34;: &#34;collision&#34;,&#10;  &#34;incidentDate&#34;: &#34;2026-06-01&#34;,&#10;  &#34;damageDescription&#34;: &#34;Rear-end collision at traffic light. Other driver confirmed at fault. Police report filed on-site (report #WR-2026-44821). Damage to rear bumper and trunk. Repair estimate from certified body shop attached.&#34;,&#10;  &#34;claimDocuments&#34;: null&#10;}" />
        </zeebe:properties>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_StartToAHSP</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="Agent_ClaimsAssessment" name="Assess Claim" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.jobworker.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent-job-worker:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_MODEL}}" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are a claims assessment agent for Camunda Insurance. The customer has submitted their claim form including personal details, claim description, and optionally supporting documents (photos, repair estimates, police reports) which if present are attached to this request. Use ALL THREE tools in this sequence: (1) PolicyLookup - validates policy coverage and fraud flags; call it with the claimId. (2) GetCustomerProfile - retrieves customer fraud history and risk rating; call it with the customerId (format CUST-####, NOT the claimId - these are different identifiers). (3) CalculateDamageEstimate - computes repair estimate and anomaly flags; call it with the claimId. DOCUMENTS: if supporting documents are attached, use their content as evidence when forming your assessment. Set documentsVerified: true if documents are present and sufficient, or if no documents were submitted but the damage description is detailed enough to proceed. Set documentsVerified: false only if the claim description is so vague that assessment is impossible. Do NOT use RequestAdditionalDocuments or EscalateToHuman just because documents are absent - the damage description is sufficient evidence. FRAUD HANDLING: if any tool returns fraud signals (fraudRiskScore high, fraudFlags present, fraudHistory true, priorFraudInvestigations, anomalyFlags) document ALL of them in the fraudIndicators field as a summary string and set fraudSuspected: true. Do NOT use EscalateToHuman because of fraud suspicion - complete the full assessment and make the routing decision yourself. Reserve EscalateToHuman ONLY for genuine cannot-complete situations: critical data unavailable or tools failing repeatedly. When done return JSON only: {claimSummary: string, policyValidated: boolean, documentsVerified: boolean, damageEstimate: number, fraudIndicators: string, fraudSuspected: boolean, decision: string, decisionRationale: string, suggestedSettlementAmount: number} where decision must be exactly one of: APPROVE (clean low-risk claim, no fraud signals), MANUAL_REVIEW (ambiguous — some uncertainty but no hard fraud indicators), ESCALATE (fraudSuspected true, multiple fraud flags, coverage added shortly before incident, claimed amount far exceeds vehicle value, prior fraud history, open fraud investigations, or multiple recent claims in short period). Err toward ESCALATE when risk is elevated.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;Assess claim ID &#34; + claimId + &#34;. Customer reported: &#34; + damageDescription" target="data.userPrompt.prompt" />
          <zeebe:input source="=if is defined(claimDocuments) then claimDocuments else null" target="data.userPrompt.documents" />
          <zeebe:input target="agentContext" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="20" target="data.limits.maxModelCalls" />
          <zeebe:input source="WAIT_FOR_TOOL_CALL_RESULTS" target="data.events.behavior" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=true" target="data.response.format.parseJson" />
          <zeebe:input source="=false" target="data.response.includeAssistantMessage" />
          <zeebe:input source="=true" target="data.response.includeAgentContext" />
          <zeebe:input target="agent" />
          <zeebe:output source="=agent" target="agent" />
          <zeebe:output source="=agent.responseJson.decision" target="claimDecision" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.jobworker.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
        <zeebe:adHoc outputCollection="toolCallResults" outputElement="={&#10;  id: toolCall._meta.id,&#10;  name: toolCall._meta.name,&#10;  content: toolCallResult&#10;}" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_StartToAHSP</bpmn:incoming>
      <bpmn:outgoing>Flow_AHSPToJudge</bpmn:outgoing>
      <bpmn:serviceTask id="PolicyLookup" name="Look up policy" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Look up insurance policy by claim ID. Returns policy holder name, coverage type, limits, and active status. Call first to confirm the claim has valid coverage.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.claimId, &#34;Claim ID to look up policy for&#34;, &#34;string&#34;)" target="claimId" />
            <zeebe:input source="=false" target="ignoreNullValues" />
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="=&#34;https://claim-demo.free.beeceptor.com/claims/&#34; + toolCall.claimId" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:output source="=toolCallResult" target="toolCallResult" />
            <zeebe:output source="=toolCallResult.policyNumber" target="policyNumber" />
            <zeebe:output source="=toolCallResult.status" target="policyStatus" />
            <zeebe:output source="=toolCallResult.coverageLimit" target="coverageLimit" />
            <zeebe:output source="=toolCallResult.deductible" target="deductible" />
            <zeebe:output source="=toolCallResult.fraudRiskScore" target="fraudRiskScore" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={toolCallResult: response.body}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="GetCustomerProfile" name="Get customer profile" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Retrieve the customer profile and full claims history in one call. Returns contact details, account standing, fraud risk score, past claims count, last claim date and amount, and fraud history. Call once to understand both the customer context and their claims track record.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.customerId, &#34;Customer ID to fetch profile for&#34;, &#34;string&#34;)" target="customerId" />
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="=&#34;https://claim-demo.free.beeceptor.com/customers/&#34; + toolCall.customerId" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:input source="=false" target="ignoreNullValues" />
            <zeebe:output source="=toolCallResult" target="toolCallResult" />
            <zeebe:output source="=toolCallResult.tier" target="customerTier" />
            <zeebe:output source="=toolCallResult.accountStatus" target="accountStatus" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={toolCallResult: response.body}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="CalculateDamageEstimate" name="Calculate damage estimate" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="12" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:documentation>Calculate a damage estimate based on claim type, reported description, and supporting documents. Returns an estimated repair or replacement cost. Call after reviewing documents to quantify the claim value.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.claimId, &#34;Claim ID to calculate damage for&#34;, &#34;string&#34;)" target="claimId" />
            <zeebe:input source="=fromAi(toolCall.damageDescription, &#34;Description of the reported damage&#34;, &#34;string&#34;)" target="damageDescription" />
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="POST" target="method" />
            <zeebe:input source="=&#34;https://claim-demo.free.beeceptor.com/claims/&#34; + toolCall.claimId + &#34;/estimate&#34;" target="url" />
            <zeebe:input source="={damageDescription: toolCall.damageDescription}" target="body" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:input source="=false" target="ignoreNullValues" />
            <zeebe:output source="=toolCallResult" target="toolCallResult" />
            <zeebe:output source="=toolCallResult.estimatedAmount" target="damageEstimate" />
            <zeebe:output source="=toolCallResult.repairCategory" target="damageCategory" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="12" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={toolCallResult: response.body}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:userTask id="RequestAdditionalDocuments" name="Request additional documents">
        <bpmn:documentation>Ask the customer to provide additional supporting documents that are missing or insufficient. Use when the existing documents are incomplete for a proper assessment. A claims processor will contact the customer and confirm receipt.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="request-additional-docs-form" />
          <zeebe:assignmentDefinition candidateGroups="claims-processors" />
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.claimId, &#34;Claim ID that needs additional documents&#34;, &#34;string&#34;)" target="claimId" />
            <zeebe:input source="=fromAi(toolCall.missingDocuments, &#34;List of missing or insufficient documents needed&#34;, &#34;string&#34;)" target="missingDocuments" />
            <zeebe:output source="=documentsReceived" target="toolCallResult" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
      </bpmn:userTask>
      <bpmn:intermediateThrowEvent id="EscalateToHuman" name="Cannot complete - escalate">
        <bpmn:documentation>Use this tool ONLY when you genuinely cannot complete the claim assessment: critical documents are missing or unreadable, conflicting information that cannot be resolved with available tools, unusual claim type outside your assessment scope, or tools failing repeatedly after retries. Do NOT use for suspected fraud - fraud suspicion is the judge's job; complete the assessment and set fraudSuspected: true instead. Do NOT use as a fallback for transient tool failures - retry first. Provide a clear reason so the adjuster can prepare.</bpmn:documentation>
        <bpmn:extensionElements>
          <zeebe:ioMapping>
            <zeebe:input source="=fromAi(toolCall.reason, &#34;Reason why the claim assessment cannot be completed autonomously and requires human review&#34;, &#34;string&#34;)" target="escalationReason" />
          </zeebe:ioMapping>
        </bpmn:extensionElements>
        <bpmn:escalationEventDefinition escalationRef="Escalation_Claims" />
      </bpmn:intermediateThrowEvent>
    </bpmn:adHocSubProcess>
    <bpmn:boundaryEvent id="Boundary_AssessmentError" name="Assessment error" attachedToRef="Agent_ClaimsAssessment">
      <bpmn:outgoing>Flow_BoundaryToError</bpmn:outgoing>
      <bpmn:errorEventDefinition />
    </bpmn:boundaryEvent>
    <bpmn:userTask id="Task_HandleError" name="Handle assessment failure">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="assessment-failure-form" />
        <zeebe:assignmentDefinition candidateGroups="claims-supervisors" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_BoundaryToError</bpmn:incoming>
      <bpmn:outgoing>Flow_ErrorToEnd</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_AssessmentError" name="Error handled">
      <bpmn:incoming>Flow_ErrorToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Agent_Judge" name="Quality Judge" zeebe:modelerTemplate="io.camunda.connectors.agenticai.aiagent.v1" zeebe:modelerTemplateVersion="5" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.agenticai:aiagent:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="bedrock" target="provider.type" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_REGION}}" target="provider.bedrock.region" />
          <zeebe:input source="credentials" target="provider.bedrock.authentication.type" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_ACCESS_KEY}}" target="provider.bedrock.authentication.accessKey" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_SECRET_KEY}}" target="provider.bedrock.authentication.secretKey" />
          <zeebe:input source="{{secrets.AWS_BEDROCK_MODEL}}" target="provider.bedrock.model.model" />
          <zeebe:input source="=&#34;You are a quality evaluator for an AI claims assessment agent at Camunda Insurance. Your job is NOT to make the claim routing decision — the assessment agent already did that. Your job is to evaluate HOW WELL the agent performed its assessment. Score the following four dimensions from 0.0 to 1.0: (1) toolCompleteness — did the agent call all three expected tools (PolicyLookup, GetCustomerProfile, CalculateDamageEstimate)? Score 1.0 for all three called, 0.67 for two, 0.33 for one, 0.0 for none. (2) fraudAnalysisDepth — did the agent thoroughly surface and document fraud signals from tool results? Were fraudIndicators populated when signals were present? Did fraudSuspected accurately reflect the evidence? (3) decisionJustification — is the agent&#39;s decision clearly supported by the evidence gathered? Is decisionRationale specific and grounded in tool results? (4) responseCompleteness — did the agent populate all required output fields without nulls or placeholders (claimSummary, policyValidated, documentsVerified, damageEstimate, fraudIndicators, fraudSuspected, decision, decisionRationale, suggestedSettlementAmount)? Respond with JSON only: {toolCompleteness: number, fraudAnalysisDepth: number, decisionJustification: number, responseCompleteness: number, overallScore: number, feedback: string} where overallScore is the arithmetic mean of the four scores and feedback is one to two sentences of actionable improvement notes for the assessment agent. OUTPUT FORMAT (strict): your entire final message must be ONLY the raw JSON object — it must start with { and end with } with no markdown code fences, no preamble, and no commentary outside the JSON. Always return a complete object containing every field (toolCompleteness, fraudAnalysisDepth, decisionJustification, responseCompleteness, overallScore, feedback); never end your turn on a tool call or an empty message.&#34;" target="data.systemPrompt.prompt" />
          <zeebe:input source="=&#34;Evaluate the following claims assessment. Tools called during assessment: &#34; + string(toolCallResults) + &#34;. Final assessment report: &#34; + agent.responseText" target="data.userPrompt.prompt" />
          <zeebe:input source="in-process" target="data.memory.storage.type" />
          <zeebe:input source="=20" target="data.memory.contextWindowSize" />
          <zeebe:input source="=5" target="data.limits.maxModelCalls" />
          <zeebe:input source="text" target="data.response.format.type" />
          <zeebe:input source="=true" target="data.response.format.parseJson" />
          <zeebe:input source="=true" target="data.response.includeAssistantMessage" />
          <zeebe:output source="=agentJudge" target="agentJudge" />
          <zeebe:output source="=if is defined(agentJudge.responseJson) then agentJudge.responseJson else null" target="qualityScores" />
          <zeebe:output source="=if is defined(agentJudge.responseJson) then agentJudge.responseJson.overallScore else null" target="agentQualityScore" />
          <zeebe:output source="=if is defined(agentJudge.responseJson) then agentJudge.responseJson.feedback else null" target="qualityFeedback" />
          <zeebe:output source="=if is defined(agentJudge.responseText) then agentJudge.responseText else null" target="judgeRawResponse" />
          <zeebe:output source="=agent.responseText" target="assessmentReport" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="5" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.agenticai.aiagent.v1" />
          <zeebe:header key="resultVariable" value="agentJudge" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_AHSPToJudge</bpmn:incoming>
      <bpmn:outgoing>Flow_JudgeToGW</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_JudgeDecision" name="Claim decision?" default="Flow_GWToEscalate">
      <bpmn:incoming>Flow_JudgeToGW</bpmn:incoming>
      <bpmn:outgoing>Flow_GWToApprove</bpmn:outgoing>
      <bpmn:outgoing>Flow_GWToManual</bpmn:outgoing>
      <bpmn:outgoing>Flow_GWToEscalate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_ClaimApproved" name="Claim approved">
      <bpmn:incoming>Flow_GWToApprove</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_ManualReview" name="Manual claim review">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="manual-review-form" />
        <zeebe:assignmentDefinition candidateGroups="adjusters-team" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_GWToManual</bpmn:incoming>
      <bpmn:outgoing>Flow_ManualToNotify</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="End_ManualResolved" name="Claim manually resolved">
      <bpmn:incoming>Flow_ManualToNotify</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:intermediateThrowEvent id="Event_EscalateThrow" name="Escalate to adjuster">
      <bpmn:incoming>Flow_GWToEscalate</bpmn:incoming>
      <bpmn:escalationEventDefinition escalationRef="Escalation_Claims" />
    </bpmn:intermediateThrowEvent>
    <bpmn:subProcess id="SubProcess_HumanControl" name="Human Control" triggeredByEvent="true">
      <bpmn:startEvent id="Start_HumanEscalation" name="Claim escalated to human">
        <bpmn:outgoing>Flow_HumanStart</bpmn:outgoing>
        <bpmn:escalationEventDefinition escalationRef="Escalation_Claims" />
      </bpmn:startEvent>
      <bpmn:userTask id="Task_HumanReview" name="Handle escalated claim">
        <bpmn:extensionElements>
          <zeebe:userTask />
          <zeebe:formDefinition formId="escalated-claim-form" />
          <zeebe:assignmentDefinition candidateGroups="adjusters-team" />
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_HumanStart</bpmn:incoming>
        <bpmn:outgoing>Flow_HumanToNotify</bpmn:outgoing>
      </bpmn:userTask>
      <bpmn:endEvent id="End_HumanResolved" name="Escalation resolved">
        <bpmn:incoming>Flow_HumanToNotify</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_HumanStart" sourceRef="Start_HumanEscalation" targetRef="Task_HumanReview" />
      <bpmn:sequenceFlow id="Flow_HumanToNotify" sourceRef="Task_HumanReview" targetRef="End_HumanResolved" />
    </bpmn:subProcess>
    <bpmn:sequenceFlow id="Flow_StartToAHSP" sourceRef="Start_ClaimForm" targetRef="Agent_ClaimsAssessment" />
    <bpmn:sequenceFlow id="Flow_AHSPToJudge" sourceRef="Agent_ClaimsAssessment" targetRef="Agent_Judge" />
    <bpmn:sequenceFlow id="Flow_BoundaryToError" sourceRef="Boundary_AssessmentError" targetRef="Task_HandleError" />
    <bpmn:sequenceFlow id="Flow_ErrorToEnd" sourceRef="Task_HandleError" targetRef="End_AssessmentError" />
    <bpmn:sequenceFlow id="Flow_JudgeToGW" sourceRef="Agent_Judge" targetRef="Gateway_JudgeDecision" />
    <bpmn:sequenceFlow id="Flow_GWToApprove" name="Approve" sourceRef="Gateway_JudgeDecision" targetRef="End_ClaimApproved">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=claimDecision = "APPROVE"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_GWToManual" name="Manual review" sourceRef="Gateway_JudgeDecision" targetRef="Task_ManualReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=claimDecision = "MANUAL_REVIEW"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ManualToNotify" sourceRef="Task_ManualReview" targetRef="End_ManualResolved" />
    <bpmn:sequenceFlow id="Flow_GWToEscalate" sourceRef="Gateway_JudgeDecision" targetRef="Event_EscalateThrow" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="CamundaInsurance_ClaimsProcessing">
      <bpmndi:BPMNShape id="Start_ClaimForm_di" bpmnElement="Start_ClaimForm">
        <dc:Bounds x="152" y="182" width="36" height="36" />
