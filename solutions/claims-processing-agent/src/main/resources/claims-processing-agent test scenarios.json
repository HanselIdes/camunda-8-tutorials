        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Unresolvable claim — agent escalates to adjuster",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "variables": {
            "customerName": "Esc Test",
            "customerId": "CUST-0530",
            "customerEmail": "esc.test@email.com",
            "claimId": "CLM-2025-0530",
            "claimType": "liability",
            "incidentDate": "2026-02-20",
            "damageDescription": "Third-party liability claim with two conflicting police reports and disputed fault. The available tools cannot resolve the contradiction, so the assessment agent escalates to a human adjuster.",
            "claimDocuments": null
