{
  "processId": "CamundaInsurance_ClaimsProcessing",
  "testCases": [
    {
      "name": "Clean claim — auto-approved",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "variables": {
            "customerName": "Jane Smith",
            "customerId": "CUST-0500",
            "customerEmail": "jane.smith@email.com",
            "claimId": "CLM-2025-0500",
            "claimType": "collision",
            "incidentDate": "2026-05-01",
            "damageDescription": "Minor parking-lot bump to the rear bumper. Active comprehensive policy, clean claims history. Body-shop repair estimate of €500 and dashcam footage attached.",
            "claimDocuments": null
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Underdocumented claim — returned for documents",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "variables": {
            "customerName": "Doc Needed",
            "customerId": "CUST-0510",
            "customerEmail": "doc.needed@email.com",
            "claimId": "CLM-2025-0510",
            "claimType": "flood",
            "incidentDate": "2026-03-10",
            "damageDescription": "Basement and garage flooded after heavy rain, €5,000 claimed. No photos, no plumber report, and no repair invoice provided. Documentation is insufficient to assess.",
            "claimDocuments": null
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "RequestAdditionalDocuments"
          },
          "variables": {
            "documentsReceived": true
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Fraudulent claim — escalated to adjuster",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "variables": {
            "customerName": "Maria Kovacs",
            "customerId": "CUST-4521",
            "customerEmail": "maria.kovacs@email.com",
            "claimId": "CLM-2025-0042",
            "claimType": "collision",
            "incidentDate": "2026-06-01",
            "damageDescription": "Total-loss collision claimed at €48,000. Collision coverage added 8 days before the incident. Customer has a prior fraud investigation and multiple recent claims. Referenced police report cannot be verified.",
            "claimDocuments": null
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Task_HumanReview"
          },
          "variables": {
            "adjusterResolution": "DENY",
            "adjusterNotes": "Fraud confirmed across multiple indicators. Claim denied and referred to the Special Investigations Unit."
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Borderline claim — manual review",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": {
            "processDefinitionId": "CamundaInsurance_ClaimsProcessing"
          },
          "variables": {
            "customerName": "Tom Borderline",
            "customerId": "CUST-0520",
            "customerEmail": "tom.borderline@email.com",
            "claimId": "CLM-2025-0520",
            "claimType": "theft",
            "incidentDate": "2026-04-15",
            "damageDescription": "Vehicle stolen from a driveway overnight, €12,000 claimed. No witnesses and no CCTV. Medium risk rating, no hard fraud indicators, but circumstances are ambiguous.",
            "claimDocuments": null
          }
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": {
            "elementId": "Task_ManualReview"
          },
