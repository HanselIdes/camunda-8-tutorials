    },
    {
      "name": "AHSP throws error — assessment failure handled by supervisor",
      "description": "The AHSP outer job throws a BPMN error (agent connector failure). Boundary_AssessmentError fires, Task_HandleError becomes active, process ends at End_AssessmentError.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "variables": {
            "claimId": "CLM-TEST-ERR",
            "customerId": "CUST-ERR",
            "claimType": "collision",
            "damageDescription": "Test claim for error boundary.",
            "customerName": "Error Test",
            "customerEmail": "error@example.com",
            "incidentDate": "2026-01-01"
          }
        },
        {
          "type": "THROW_BPMN_ERROR_FROM_JOB",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "errorCode": "AGENT_ERROR",
          "errorMessage": "Agent connector unavailable. Bedrock endpoint timeout."
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "elementSelectors": [{ "elementId": "Task_HandleError" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": { "elementId": "Task_HandleError" },
          "variables": { "supervisorNotes": "Agent connector was unavailable. Claim re-queued manually." }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "elementSelectors": [{ "elementId": "End_AssessmentError" }],
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "state": "IS_COMPLETED"
        }
      ]
    },
