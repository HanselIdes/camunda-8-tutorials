    {
      "name": "agent cannot complete — EscalateToHuman tool fires from AHSP",
      "description": "Agent encounters an unresolvable conflict and activates the EscalateToHuman escalation tool. Escalation propagates out of the AHSP, SubProcess_HumanControl catches it, adjuster resolves.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "variables": {
            "claimId": "CLM-TEST-ESC",
            "customerId": "CUST-ESC",
            "claimType": "liability",
            "damageDescription": "Third-party liability claim. Conflicting police reports.",
            "customerName": "Esc Test",
            "customerEmail": "esc@example.com",
            "incidentDate": "2026-02-20"
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "context": {
                "state": "WAITING_FOR_TOOL_CALL_RESULTS",
                "metrics": { "modelCalls": 1, "tokenUsage": { "inputTokenCount": 350, "outputTokenCount": 45 } },
                "conversation": { "type": "in-process", "messages": [] }
              }
            },
            "escalationReason": "Conflicting police reports cannot be resolved with available tools. Requires human adjuster."
          },
          "completionConditionFulfilled": false,
          "activateElements": [
            {
              "elementId": "EscalateToHuman",
              "variables": {
                "toolCall": {
                  "_meta": { "id": "t1", "name": "EscalateToHuman" },
                  "reason": "Conflicting police reports cannot be resolved with available tools."
                }
              }
            }
          ]
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "elementSelectors": [{ "elementId": "Task_HumanReview" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": { "elementId": "Task_HumanReview" },
          "variables": {
            "adjusterResolution": "APPROVE",
            "adjusterNotes": "Reviewed conflicting reports. Adjuster confirms partial settlement."
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ]
