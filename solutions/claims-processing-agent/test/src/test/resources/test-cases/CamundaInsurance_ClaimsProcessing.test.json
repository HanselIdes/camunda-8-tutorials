{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "clean claim — judge approves",
      "description": "Low-risk collision claim. Agent activates three tools (round 1), receives results, provides final assessment (round 2). Judge decides APPROVE. Process ends at End_ClaimApproved.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "variables": {
            "claimId": "CLM-TEST-001",
            "customerId": "CUST-0001",
            "claimType": "collision",
            "damageDescription": "Minor rear-end impact in parking lot. Repair estimate $1,200.",
            "customerName": "Jane Smith",
            "customerEmail": "jane.smith@example.com",
            "incidentDate": "2026-05-01"
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "context": {
                "state": "WAITING_FOR_TOOL_CALL_RESULTS",
                "metrics": { "modelCalls": 1, "tokenUsage": { "inputTokenCount": 420, "outputTokenCount": 60 } },
                "conversation": { "type": "in-process", "messages": [] }
              }
            }
          },
          "completionConditionFulfilled": false,
          "activateElements": [
            { "elementId": "PolicyLookup",            "variables": { "toolCall": { "_meta": { "id": "t1", "name": "PolicyLookup" },            "claimId": "CLM-TEST-001" } } },
            { "elementId": "GetCustomerProfile",      "variables": { "toolCall": { "_meta": { "id": "t2", "name": "GetCustomerProfile" },      "customerId": "CUST-0001" } } },
            { "elementId": "CalculateDamageEstimate", "variables": { "toolCall": { "_meta": { "id": "t3", "name": "CalculateDamageEstimate" }, "claimId": "CLM-TEST-001", "damageDescription": "Minor rear-end impact" } } }
          ]
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "PolicyLookup" },
          "variables": {
            "toolCallResult": { "policyNumber": "POL-001", "status": "active", "coverageLimit": 50000, "deductible": 500, "fraudRiskScore": "low", "fraudFlags": 0 }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "GetCustomerProfile" },
          "variables": {
            "toolCallResult": { "tier": "standard", "accountStatus": "active", "riskRating": "low", "fraudHistory": false, "priorFraudInvestigations": 0, "openInvestigations": 0, "claimsThisYear": 0 }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "CalculateDamageEstimate" },
          "variables": {
            "toolCallResult": { "estimatedAmount": 1200, "repairCategory": "minor", "estimateConfidence": "high", "anomalyFlags": [] }
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "responseText": "{\"claimSummary\":\"Minor collision claim with clean policy history.\",\"policyValidated\":true,\"documentsVerified\":true,\"damageEstimate\":1200,\"fraudIndicators\":\"\",\"fraudSuspected\":false,\"recommendedAction\":\"Approve claim.\",\"reportComplete\":true}",
              "context": {
                "state": "READY",
                "metrics": { "modelCalls": 2, "tokenUsage": { "inputTokenCount": 900, "outputTokenCount": 120 } },
                "conversation": { "type": "in-process", "messages": [] }
              }
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Agent_Judge" },
          "variables": {
            "agentJudge": {
              "responseJson": {
                "decision": "APPROVE",
                "reasoning": "Clean claim with no fraud indicators. Damage estimate is reasonable.",
                "confidence": 0.97,
                "suggestedSettlementAmount": 700
              }
            }
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "elementSelectors": [{ "elementId": "End_ClaimApproved" }],
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "high-fraud claim — judge escalates, adjuster resolves",
      "description": "Multiple fraud indicators. Agent assesses all three tools, judge decides ESCALATE (default branch), event subprocess catches escalation, adjuster completes Task_HumanReview.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "variables": {
            "claimId": "CLM-TEST-002",
            "customerId": "CUST-9999",
            "claimType": "collision",
            "damageDescription": "Total-loss collision. Repair estimate $47,800.",
            "customerName": "Bad Actor",
            "customerEmail": "fraud@example.com",
            "incidentDate": "2026-06-01"
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "context": {
                "state": "WAITING_FOR_TOOL_CALL_RESULTS",
                "metrics": { "modelCalls": 1, "tokenUsage": { "inputTokenCount": 460, "outputTokenCount": 55 } },
                "conversation": { "type": "in-process", "messages": [] }
              }
            }
          },
          "completionConditionFulfilled": false,
          "activateElements": [
            { "elementId": "PolicyLookup",            "variables": { "toolCall": { "_meta": { "id": "t1", "name": "PolicyLookup" },            "claimId": "CLM-TEST-002" } } },
            { "elementId": "GetCustomerProfile",      "variables": { "toolCall": { "_meta": { "id": "t2", "name": "GetCustomerProfile" },      "customerId": "CUST-9999" } } },
            { "elementId": "CalculateDamageEstimate", "variables": { "toolCall": { "_meta": { "id": "t3", "name": "CalculateDamageEstimate" }, "claimId": "CLM-TEST-002", "damageDescription": "Total-loss collision" } } }
          ]
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "PolicyLookup" },
          "variables": {
            "toolCallResult": { "policyNumber": "POL-BAD", "status": "active", "coverageLimit": 50000, "deductible": 500, "fraudRiskScore": "high", "fraudFlags": 3 }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "GetCustomerProfile" },
          "variables": {
            "toolCallResult": { "tier": "standard", "accountStatus": "active", "riskRating": "high", "fraudHistory": true, "priorFraudInvestigations": 2, "openInvestigations": 1, "claimsThisYear": 4 }
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "CalculateDamageEstimate" },
          "variables": {
            "toolCallResult": { "estimatedAmount": 47800, "repairCategory": "total-loss", "estimateConfidence": "low", "anomalyFlags": ["amount_exceeds_vehicle_value"] }
          }
        },
        {
          "type": "COMPLETE_JOB_AD_HOC_SUB_PROCESS",
          "jobSelector": { "jobType": "io.camunda.agenticai:aiagent-job-worker:1" },
          "variables": {
            "agent": {
              "responseText": "{\"claimSummary\":\"Highly suspicious claim.\",\"policyValidated\":true,\"documentsVerified\":true,\"damageEstimate\":47800,\"fraudIndicators\":\"Coverage added 12 days before incident. Estimate 5.2x vehicle value.\",\"fraudSuspected\":true,\"recommendedAction\":\"Suspend and refer to SIU.\",\"reportComplete\":true}",
              "context": {
                "state": "READY",
                "metrics": { "modelCalls": 2, "tokenUsage": { "inputTokenCount": 1200, "outputTokenCount": 280 } },
                "conversation": { "type": "in-process", "messages": [] }
              }
            }
          },
          "completionConditionFulfilled": true
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Agent_Judge" },
          "variables": {
            "agentJudge": {
              "responseJson": {
                "decision": "ESCALATE",
                "reasoning": "Multiple hard escalation triggers: fraudSuspected, coverage timing, inflated estimate.",
                "confidence": 0.99,
                "suggestedSettlementAmount": 0
              }
            }
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "elementSelectors": [{ "elementId": "Task_HumanReview" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_USER_TASK",
          "userTaskSelector": { "elementId": "Task_HumanReview" },
          "variables": {
            "adjusterResolution": "DENY",
            "adjusterNotes": "Fraud confirmed. Claim denied and referred to SIU."
          }
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "CamundaInsurance_ClaimsProcessing" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
