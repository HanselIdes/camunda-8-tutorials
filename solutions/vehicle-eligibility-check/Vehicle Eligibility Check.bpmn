<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:ns1="modeler" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:ns0="xmlns" id="bpmn_copilot_Definition_id" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="a73dc72" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0" ns0:modeler="http://camunda.org/schema/modeler/1.0" ns1:executionPlatform="Camunda Cloud" ns1:executionPlatformVersion="8.6">
  <bpmn:process id="vehicle-eligibility-check" name="Vehicle Eligibility Check" processType="None" isClosed="false" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="VIN Received">
      <bpmn:outgoing>Flow_1u5ktjv</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1u5ktjv" sourceRef="StartEvent_1" targetRef="Activity_0k1w3q7" />
    <bpmn:serviceTask id="Activity_0k1w3q7" name="Look up VIN" zeebe:modelerTemplate="io.camunda.demo:nhtsa-vehicle-lookup:1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/png;base64," implementation="##WebService">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="get" target="method" />
          <zeebe:input source="= &#34;https://vpic.nhtsa.dot.gov/api/vehicles/decodevin/&#34; + vin + &#34;?format=json&#34;" target="url" />
          <zeebe:input target="queryParameters" />
          <zeebe:input target="headers" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="vehicleApiResponse" />
          <zeebe:header key="resultExpression" value="={&#10;   &#34;make&#34;: vehicleApiResponse.body.Results[Variable=&#34;Make&#34;][1].Value,&#10;   &#34;model&#34;: vehicleApiResponse.body.Results[Variable=&#34;Model&#34;][1].Value,&#10;   &#34;year&#34;: number(vehicleApiResponse.body.Results[Variable=&#34;Model Year&#34;][1].Value),&#10;   &#34;vehicle type&#34;: vehicleApiResponse.body.Results[Variable=&#34;Vehicle Type&#34;][1].Value&#10;}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1u5ktjv</bpmn:incoming>
      <bpmn:outgoing>Flow_0y1b7qj</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0y1b7qj" sourceRef="Activity_0k1w3q7" targetRef="Activity_1c9x8wj" />
    <bpmn:sequenceFlow id="Flow_1q0c5z2" sourceRef="Activity_1c9x8wj" targetRef="Gateway_1o0w8qf" />
    <bpmn:exclusiveGateway id="Gateway_1o0w8qf" name="Vehicle Eligible?" default="Flow_0n3g4h5">
      <bpmn:incoming>Flow_1q0c5z2</bpmn:incoming>
      <bpmn:outgoing>Flow_1a8b7c6</bpmn:outgoing>
      <bpmn:outgoing>Flow_0n3g4h5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_1a8b7c6" name="Yes" sourceRef="Gateway_1o0w8qf" targetRef="Activity_0f9d8e7">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=eligible</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:task id="Activity_0f9d8e7" name="Add to Promo List">
      <bpmn:incoming>Flow_1a8b7c6</bpmn:incoming>
      <bpmn:outgoing>Flow_1p2q3r4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_1m2n3o4" name="Eligible">
      <bpmn:incoming>Flow_1p2q3r4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1p2q3r4" sourceRef="Activity_0f9d8e7" targetRef="Event_1m2n3o4" />
    <bpmn:sequenceFlow id="Flow_0n3g4h5" name="No" sourceRef="Gateway_1o0w8qf" targetRef="Activity_1x2y3z4" />
    <bpmn:task id="Activity_1x2y3z4" name="Log Ineligibility">
      <bpmn:incoming>Flow_0n3g4h5</bpmn:incoming>
      <bpmn:outgoing>Flow_0a1b2c3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_0d1e2f3" name="Ineligible">
      <bpmn:incoming>Flow_0a1b2c3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0a1b2c3" sourceRef="Activity_1x2y3z4" targetRef="Event_0d1e2f3" />
    <bpmn:serviceTask id="Activity_1c9x8wj" name="Calculate Eligibility">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda.demo:vehicle-risk-assessment" />
        <zeebe:ioMapping>
          <zeebe:output source="=riskScore" target="riskScore" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0y1b7qj</bpmn:incoming>
      <bpmn:outgoing>Flow_1q0c5z2</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_vehicle-lookup">
    <bpmndi:BPMNPlane id="BPMNPlane_vehicle-lookup" bpmnElement="vehicle-eligibility-check">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0k1w3q7_di" bpmnElement="Activity_0k1w3q7">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1o0w8qf_di" bpmnElement="Gateway_1o0w8qf" isMarkerVisible="true">
        <dc:Bounds x="500" y="45" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="484" y="21" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0f9d8e7_di" bpmnElement="Activity_0f9d8e7">
        <dc:Bounds x="625" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1m2n3o4_di" bpmnElement="Event_1m2n3o4">
        <dc:Bounds x="807" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1x2y3z4_di" bpmnElement="Activity_1x2y3z4">
        <dc:Bounds x="625" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0d1e2f3_di" bpmnElement="Event_0d1e2f3">
        <dc:Bounds x="807" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1gb9esn_di" bpmnElement="Activity_1c9x8wj">
        <dc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1u5ktjv_di" bpmnElement="Flow_1u5ktjv">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0y1b7qj_di" bpmnElement="Flow_0y1b7qj">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1q0c5z2_di" bpmnElement="Flow_1q0c5z2">
        <di:waypoint x="425" y="70" />
        <di:waypoint x="500" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1a8b7c6_di" bpmnElement="Flow_1a8b7c6">
        <di:waypoint x="550" y="70" />
        <di:waypoint x="625" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1p2q3r4_di" bpmnElement="Flow_1p2q3r4">
        <di:waypoint x="725" y="70" />
        <di:waypoint x="807" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0n3g4h5_di" bpmnElement="Flow_0n3g4h5">
        <di:waypoint x="525" y="95" />
        <di:waypoint x="525" y="210" />
        <di:waypoint x="625" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0a1b2c3_di" bpmnElement="Flow_0a1b2c3">
        <di:waypoint x="725" y="210" />
        <di:waypoint x="807" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
