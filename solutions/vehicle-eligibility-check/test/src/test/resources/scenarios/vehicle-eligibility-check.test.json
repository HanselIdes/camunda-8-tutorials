{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Eligible vehicle — routes to Promo Applied end event",
      "description": "2023 PASSENGER CAR: DMN rule 1, eligible=true, riskScore=5. Covers eligible path: StartEvent_1 → Activity_0k5z3x2 → Activity_1c6x9f4 → Gateway_1m4n5p6 → Activity_0f7g8h9 → Event_1q2w3e4.",
      "instructions": [
        {
          "type": "MOCK_JOB_WORKER_COMPLETE_JOB",
          "jobType": "io.camunda:http-json:1",
          "variables": {
            "year": 2023,
            "make": "HONDA",
            "model": "CIVIC",
            "vehicleType": "PASSENGER CAR"
          }
        },
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "2HGFE2F57NH123456" }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "Event_1q2w3e4" }],
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Ineligible vehicle — routes to Process Ended end event",
