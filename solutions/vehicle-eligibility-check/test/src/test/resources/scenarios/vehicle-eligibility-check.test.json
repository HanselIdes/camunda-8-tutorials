{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Eligible vehicle — promo applied",
      "description": "2023 Honda Civic (PASSENGER CAR, year>=2022): DMN rule 1 fires, eligible=true. Process routes via Flow_Eligible to EndEvent_Eligible.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "2HGFE2F57NH123456" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Task_LookupVin" },
          "variables": {
            "year": 2023,
            "vehicleType": "PASSENGER CAR",
            "make": "HONDA",
            "model": "CIVIC"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "EndEvent_Eligible" }],
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Ineligible vehicle — not enrolled",
      "description": "2015 Ford F-150 (TRUCK, year<2018): DMN rule 6 fires, eligible=false. Process routes via default Flow_Ineligible to EndEvent_Ineligible.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "1FTFW1ET5EKE01234" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Task_LookupVin" },
          "variables": {
            "year": 2015,
            "vehicleType": "TRUCK",
            "make": "FORD",
            "model": "F-150"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "EndEvent_Ineligible" }],
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ]
}
