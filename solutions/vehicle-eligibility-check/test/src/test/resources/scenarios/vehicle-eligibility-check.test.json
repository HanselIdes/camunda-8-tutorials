{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Eligible vehicle — reaches Process Complete (Eligible)",
      "description": "2023 PASSENGER CAR: DMN rule 1 fires (riskScore=5, eligible=true), gateway routes to eligible path.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "2HGFE2F57NH123456" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_VinLookup" },
          "variables": {
            "year": 2023,
            "make": "HONDA",
            "model": "CIVIC",
            "vehicleType": "PASSENGER CAR"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "Event_EligibleEnd" }],
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Ineligible vehicle — reaches Process Complete (Ineligible)",
      "description": "2015 TRUCK: DMN rule 6 fires (riskScore=50, eligible=false), gateway routes to ineligible path.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "1FTFW1ET5EKE01234" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "Activity_VinLookup" },
          "variables": {
            "year": 2015,
            "make": "FORD",
            "model": "F-150",
            "vehicleType": "TRUCK"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "Event_IneligibleEnd" }],
          "state": "IS_COMPLETED"
        }
      ]
    }
  ]
}
