{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "Eligible vehicle — routes to eligible end event",
      "description": "2023 PASSENGER CAR — 2022+, personal type; DMN rule 1 fires (riskScore=5, eligible=true), gateway routes to promo-sent end event.",
      "instructions": [
        {
          "type": "MOCK_JOB_WORKER_COMPLETE_JOB",
          "jobType": "io.camunda:http-json:1",
          "variables": {
            "vehicleInfo": {
              "year": 2023,
              "make": "HONDA",
              "model": "CIVIC",
              "vehicleType": "PASSENGER CAR"
            }
          }
        },
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "2HGFE2F57NH123456" }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "EndEvent_Eligible" }],
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "Ineligible vehicle — routes to ineligible end event",
      "description": "2015 TRUCK — pre-2018, non-personal type; DMN rule 6 fires (riskScore=50, eligible=false), gateway takes default flow to rejection-sent end event.",
      "instructions": [
        {
          "type": "MOCK_JOB_WORKER_COMPLETE_JOB",
          "jobType": "io.camunda:http-json:1",
          "variables": {
            "vehicleInfo": {
              "year": 2015,
              "make": "FORD",
              "model": "F-150",
              "vehicleType": "TRUCK"
            }
          }
        },
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "variables": { "vin": "1FTFW1ET5EKE01234" }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "elementSelectors": [{ "elementId": "EndEvent_Ineligible" }],
          "state": "IS_COMPLETED"
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "vehicle-eligibility-check" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ]
}
