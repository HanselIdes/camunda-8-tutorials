<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:ns1="modeler" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:ns0="xmlns" id="bpmn_copilot_Definition_id" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="204af60" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0" ns0:modeler="http://camunda.org/schema/modeler/1.0" ns1:executionPlatform="Camunda Cloud" ns1:executionPlatformVersion="8.6">
  <bpmn:process id="vehicle-eligibility-check" name="Vehicle Eligibility Check" processType="None" isClosed="false" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="VIN Received">
      <bpmn:outgoing>Flow_1w5s7v9</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1w5s7v9" sourceRef="StartEvent_1" targetRef="Task_LookupVehicle" />
    <bpmn:serviceTask id="Task_LookupVehicle" name="Look Up Vehicle Details" zeebe:modelerTemplate="io.camunda.demo:nhtsa-vehicle-lookup:1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/png;base64," implementation="##WebService">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="get" target="method" />
          <zeebe:input source="= &#34;https://vpic.nhtsa.dot.gov/api/vehicles/decodevin/&#34; + vin + &#34;?format=json&#34;" target="url" />
          <zeebe:input target="queryParameters" />
          <zeebe:input target="headers" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="response" />
          <zeebe:header key="resultExpression" value="={&#10;        make: response.body.Results[Variable = &#34;Make&#34;][1].Value,&#10;        model: response.body.Results[Variable = &#34;Model&#34;][1].Value,&#10;        year: number(response.body.Results[Variable = &#34;Model Year&#34;][1].Value),&#10;        vehicleType: response.body.Results[Variable = &#34;Vehicle Type&#34;][1].Value&#10;    }" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1w5s7v9</bpmn:incoming>
      <bpmn:outgoing>Flow_0j2x4f8</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0j2x4f8" sourceRef="Task_LookupVehicle" targetRef="Task_DetermineEligibility" />
    <bpmn:sequenceFlow id="Flow_1q9y8z7" sourceRef="Task_DetermineEligibility" targetRef="Gateway_IsEligible" />
    <bpmn:exclusiveGateway id="Gateway_IsEligible" name="Eligible for Promo?" default="Flow_Ineligible">
      <bpmn:incoming>Flow_1q9y8z7</bpmn:incoming>
      <bpmn:outgoing>Flow_Eligible</bpmn:outgoing>
      <bpmn:outgoing>Flow_Ineligible</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Eligible" name="Yes" sourceRef="Gateway_IsEligible" targetRef="Task_NotifyEligible">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isEligible</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:task id="Task_NotifyEligible" name="Notify Customer of Eligibility">
      <bpmn:incoming>Flow_Eligible</bpmn:incoming>
      <bpmn:outgoing>Flow_0g5s4d3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_0g5s4d3" sourceRef="Task_NotifyEligible" targetRef="EndEvent_Eligible" />
    <bpmn:endEvent id="EndEvent_Eligible" name="Promo Process Started">
      <bpmn:incoming>Flow_0g5s4d3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Ineligible" name="No" sourceRef="Gateway_IsEligible" targetRef="Task_NotifyIneligible" />
    <bpmn:task id="Task_NotifyIneligible" name="Notify Customer of Ineligibility">
      <bpmn:incoming>Flow_Ineligible</bpmn:incoming>
      <bpmn:outgoing>Flow_1p0y9z8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1p0y9z8" sourceRef="Task_NotifyIneligible" targetRef="EndEvent_Ineligible" />
    <bpmn:endEvent id="EndEvent_Ineligible" name="Process Ended">
      <bpmn:incoming>Flow_1p0y9z8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_DetermineEligibility" name="Determine Eligibility">
      <bpmn:incoming>Flow_0j2x4f8</bpmn:incoming>
      <bpmn:outgoing>Flow_1q9y8z7</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_vehicle-eligibility-check">
    <bpmndi:BPMNPlane id="BPMNPlane_vehicle-eligibility-check" bpmnElement="vehicle-eligibility-check">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LookupVehicle_di" bpmnElement="Task_LookupVehicle">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_IsEligible_di" bpmnElement="Gateway_IsEligible" isMarkerVisible="true">
        <dc:Bounds x="500" y="45" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="499" y="7.5" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyEligible_di" bpmnElement="Task_NotifyEligible">
        <dc:Bounds x="625" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Eligible_di" bpmnElement="EndEvent_Eligible">
        <dc:Bounds x="807" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyIneligible_di" bpmnElement="Task_NotifyIneligible">
        <dc:Bounds x="625" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Ineligible_di" bpmnElement="EndEvent_Ineligible">
        <dc:Bounds x="807" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1a29php_di" bpmnElement="Task_DetermineEligibility">
        <dc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1w5s7v9_di" bpmnElement="Flow_1w5s7v9">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0j2x4f8_di" bpmnElement="Flow_0j2x4f8">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1q9y8z7_di" bpmnElement="Flow_1q9y8z7">
        <di:waypoint x="425" y="70" />
        <di:waypoint x="500" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Eligible_di" bpmnElement="Flow_Eligible">
        <di:waypoint x="550" y="70" />
        <di:waypoint x="625" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0g5s4d3_di" bpmnElement="Flow_0g5s4d3">
        <di:waypoint x="725" y="70" />
        <di:waypoint x="807" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Ineligible_di" bpmnElement="Flow_Ineligible">
        <di:waypoint x="525" y="95" />
        <di:waypoint x="525" y="210" />
        <di:waypoint x="625" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1p0y9z8_di" bpmnElement="Flow_1p0y9z8">
        <di:waypoint x="725" y="210" />
        <di:waypoint x="807" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
