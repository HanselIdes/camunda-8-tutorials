<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" xmlns:ns1="modeler" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:ns0="xmlns" id="bpmn_copilot_Definition_id" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Web Modeler" exporterVersion="204af60" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0" ns0:modeler="http://camunda.org/schema/modeler/1.0" ns1:executionPlatform="Camunda Cloud" ns1:executionPlatformVersion="8.6">
  <bpmn:process id="vehicle-eligibility-check" name="Vehicle Eligibility Check" processType="None" isClosed="false" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="VIN Received">
      <bpmn:outgoing>Flow_0y1k0x5</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0y1k0x5" sourceRef="StartEvent_1" targetRef="Activity_0k5w1qf" />
    <bpmn:serviceTask id="Activity_0k5w1qf" name="Look up VIN" zeebe:modelerTemplate="io.camunda.demo:nhtsa-vehicle-lookup:1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/png;base64," implementation="##WebService">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="get" target="method" />
          <zeebe:input source="= &#34;https://vpic.nhtsa.dot.gov/api/vehicles/decodevin/&#34; + vin + &#34;?format=json&#34;" target="url" />
          <zeebe:input target="queryParameters" />
          <zeebe:input target="headers" />
          <zeebe:input source="20" target="connectionTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resultVariable" value="response" />
          <zeebe:header key="resultExpression" value="={&#10;    vehicleInfo: {&#10;        make: response.body.Results[Variable=&#34;Make&#34;][1].Value,&#10;        model: response.body.Results[Variable=&#34;Model&#34;][1].Value,&#10;        year: number(response.body.Resuts[Variable=&#34;Model Year&#34;][1].Value),&#10;        vehicleType: response.body.Results[Variable=&#34;Vehicle Type&#34;][1].Value&#10;    }&#10;}" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0y1k0x5</bpmn:incoming>
      <bpmn:outgoing>Flow_1u8y7z6</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1u8y7z6" sourceRef="Activity_0k5w1qf" targetRef="Activity_1c9x4z0" />
    <bpmn:exclusiveGateway id="Gateway_1x5k2f8" name="Eligible for Promo?" default="Flow_1q0c8f7">
      <bpmn:incoming>Flow_0i8g9v4</bpmn:incoming>
      <bpmn:outgoing>Flow_0b3p7s1</bpmn:outgoing>
      <bpmn:outgoing>Flow_1q0c8f7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0i8g9v4" sourceRef="Activity_1c9x4z0" targetRef="Gateway_1x5k2f8" />
    <bpmn:task id="Activity_1f9w3e4" name="Notify Customer of Eligibility">
      <bpmn:incoming>Flow_0b3p7s1</bpmn:incoming>
      <bpmn:outgoing>Flow_1w0d2f1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_0b3p7s1" name="Yes" sourceRef="Gateway_1x5k2f8" targetRef="Activity_1f9w3e4">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=isEligible</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_0o6s5p3" name="Eligibility Confirmed">
      <bpmn:incoming>Flow_1w0d2f1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1w0d2f1" sourceRef="Activity_1f9w3e4" targetRef="Event_0o6s5p3" />
    <bpmn:task id="Activity_0a1b2c3" name="Notify Customer of Ineligibility">
      <bpmn:incoming>Flow_1q0c8f7</bpmn:incoming>
      <bpmn:outgoing>Flow_0z5x4y3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_1q0c8f7" name="No" sourceRef="Gateway_1x5k2f8" targetRef="Activity_0a1b2c3" />
    <bpmn:endEvent id="Event_1n2m3k4" name="Ineligibility Confirmed">
      <bpmn:incoming>Flow_0z5x4y3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0z5x4y3" sourceRef="Activity_0a1b2c3" targetRef="Event_1n2m3k4" />
    <bpmn:task id="Activity_1c9x4z0" name="Determine Eligibility">
      <bpmn:incoming>Flow_1u8y7z6</bpmn:incoming>
      <bpmn:outgoing>Flow_0i8g9v4</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_vehicle-eligibility-check">
    <bpmndi:BPMNPlane id="BPMNPlane_vehicle-eligibility-check" bpmnElement="vehicle-eligibility-check">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0k5w1qf_di" bpmnElement="Activity_0k5w1qf">
        <dc:Bounds x="175" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_1x5k2f8_di" bpmnElement="Gateway_1x5k2f8" isMarkerVisible="true">
        <dc:Bounds x="500" y="45" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="499" y="7.5" width="52" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1f9w3e4_di" bpmnElement="Activity_1f9w3e4">
        <dc:Bounds x="625" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0o6s5p3_di" bpmnElement="Event_0o6s5p3">
        <dc:Bounds x="807" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0a1b2c3_di" bpmnElement="Activity_0a1b2c3">
        <dc:Bounds x="625" y="170" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_1n2m3k4_di" bpmnElement="Event_1n2m3k4">
        <dc:Bounds x="807" y="192" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1gwjbg5_di" bpmnElement="Activity_1c9x4z0">
        <dc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_0y1k0x5_di" bpmnElement="Flow_0y1k0x5">
        <di:waypoint x="93" y="70" />
        <di:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1u8y7z6_di" bpmnElement="Flow_1u8y7z6">
        <di:waypoint x="275" y="70" />
        <di:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0i8g9v4_di" bpmnElement="Flow_0i8g9v4">
        <di:waypoint x="425" y="70" />
        <di:waypoint x="500" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0b3p7s1_di" bpmnElement="Flow_0b3p7s1">
        <di:waypoint x="550" y="70" />
        <di:waypoint x="625" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1w0d2f1_di" bpmnElement="Flow_1w0d2f1">
        <di:waypoint x="725" y="70" />
        <di:waypoint x="807" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1q0c8f7_di" bpmnElement="Flow_1q0c8f7">
        <di:waypoint x="525" y="95" />
        <di:waypoint x="525" y="210" />
        <di:waypoint x="625" y="210" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0z5x4y3_di" bpmnElement="Flow_0z5x4y3">
        <di:waypoint x="725" y="210" />
        <di:waypoint x="807" y="210" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
