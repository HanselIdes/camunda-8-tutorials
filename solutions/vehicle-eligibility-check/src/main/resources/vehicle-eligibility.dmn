<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="vehicleEligibilityDefinitions"
             name="Vehicle Eligibility"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="vehicleEligibility" name="Vehicle Eligibility">
    <decisionTable id="decisionTable_vehicleEligibility" hitPolicy="FIRST">
      <input id="input_year" label="Year">
        <inputExpression id="inputExpression_year" typeRef="integer">
          <text>year</text>
        </inputExpression>
      </input>
      <input id="input_vehicleType" label="Vehicle Type">
        <inputExpression id="inputExpression_vehicleType" typeRef="string">
          <text>vehicleType</text>
        </inputExpression>
      </input>
      <output id="output_riskScore" label="Risk Score" name="riskScore" typeRef="integer"/>
      <output id="output_eligible" label="Eligible" name="eligible" typeRef="boolean"/>
      <rule id="rule1">
        <description>2022+, passenger/motorcycle/MPV</description>
        <inputEntry id="inputEntry1_1"><text>&gt;= 2022</text></inputEntry>
        <inputEntry id="inputEntry1_2"><text>"PASSENGER CAR","MOTORCYCLE","MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text></inputEntry>
        <outputEntry id="outputEntry1_1"><text>5</text></outputEntry>
        <outputEntry id="outputEntry1_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule2">
        <description>2022+, any other type</description>
        <inputEntry id="inputEntry2_1"><text>&gt;= 2022</text></inputEntry>
        <inputEntry id="inputEntry2_2"><text>-</text></inputEntry>
        <outputEntry id="outputEntry2_1"><text>30</text></outputEntry>
        <outputEntry id="outputEntry2_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule3">
        <description>2018-2021, passenger/motorcycle/MPV</description>
        <inputEntry id="inputEntry3_1"><text>[2018..2021]</text></inputEntry>
        <inputEntry id="inputEntry3_2"><text>"PASSENGER CAR","MOTORCYCLE","MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text></inputEntry>
        <outputEntry id="outputEntry3_1"><text>15</text></outputEntry>
        <outputEntry id="outputEntry3_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule4">
        <description>2018-2021, any other type</description>
        <inputEntry id="inputEntry4_1"><text>[2018..2021]</text></inputEntry>
        <inputEntry id="inputEntry4_2"><text>-</text></inputEntry>
        <outputEntry id="outputEntry4_1"><text>40</text></outputEntry>
        <outputEntry id="outputEntry4_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule5">
        <description>before 2018, passenger/motorcycle/MPV</description>
        <inputEntry id="inputEntry5_1"><text>&lt; 2018</text></inputEntry>
        <inputEntry id="inputEntry5_2"><text>"PASSENGER CAR","MOTORCYCLE","MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text></inputEntry>
        <outputEntry id="outputEntry5_1"><text>25</text></outputEntry>
        <outputEntry id="outputEntry5_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule6">
        <description>before 2018, any other type — ineligible</description>
        <inputEntry id="inputEntry6_1"><text>&lt; 2018</text></inputEntry>
        <inputEntry id="inputEntry6_2"><text>-</text></inputEntry>
        <outputEntry id="outputEntry6_1"><text>50</text></outputEntry>
        <outputEntry id="outputEntry6_2"><text>false</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
