<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="VehicleEligibilityDecisions"
             name="Vehicle Eligibility Decisions"
             namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="vehicleEligibility" name="Vehicle Eligibility">
    <decisionTable id="decisionTable_vehicleEligibility" hitPolicy="FIRST">
      <input id="input_year" label="Vehicle Year">
        <inputExpression id="inputExpression_year" typeRef="integer">
          <text>vehicleInfo.year</text>
        </inputExpression>
      </input>
      <input id="input_vehicleType" label="Vehicle Type">
        <inputExpression id="inputExpression_vehicleType" typeRef="string">
          <text>vehicleInfo.vehicleType</text>
        </inputExpression>
      </input>
      <output id="output_riskScore" label="Vehicle Score" name="riskScore" typeRef="integer" />
      <output id="output_isEligible" label="Vehicle Eligible" name="isEligible" typeRef="boolean" />
      <rule id="rule_1">
        <description>2022+ passenger car, motorcycle, or MPV</description>
        <inputEntry id="inputEntry_1_1"><text>&gt;= 2022</text></inputEntry>
        <inputEntry id="inputEntry_1_2"><text>"PASSENGER CAR", "MOTORCYCLE", "MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text></inputEntry>
        <outputEntry id="outputEntry_1_1"><text>5</text></outputEntry>
        <outputEntry id="outputEntry_1_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule_2">
        <description>2022+ any other type</description>
        <inputEntry id="inputEntry_2_1"><text>&gt;= 2022</text></inputEntry>
        <inputEntry id="inputEntry_2_2"><text>-</text></inputEntry>
        <outputEntry id="outputEntry_2_1"><text>30</text></outputEntry>
        <outputEntry id="outputEntry_2_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule_3">
        <description>2018-2021 passenger car, motorcycle, or MPV</description>
        <inputEntry id="inputEntry_3_1"><text>[2018..2021]</text></inputEntry>
        <inputEntry id="inputEntry_3_2"><text>"PASSENGER CAR", "MOTORCYCLE", "MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text></inputEntry>
        <outputEntry id="outputEntry_3_1"><text>15</text></outputEntry>
        <outputEntry id="outputEntry_3_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule_4">
        <description>2018-2021 any other type</description>
        <inputEntry id="inputEntry_4_1"><text>[2018..2021]</text></inputEntry>
        <inputEntry id="inputEntry_4_2"><text>-</text></inputEntry>
        <outputEntry id="outputEntry_4_1"><text>40</text></outputEntry>
        <outputEntry id="outputEntry_4_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule_5">
        <description>Pre-2018 passenger car, motorcycle, or MPV</description>
        <inputEntry id="inputEntry_5_1"><text>&lt; 2018</text></inputEntry>
        <inputEntry id="inputEntry_5_2"><text>"PASSENGER CAR", "MOTORCYCLE", "MULTIPURPOSE PASSENGER VEHICLE (MPV)"</text></inputEntry>
        <outputEntry id="outputEntry_5_1"><text>25</text></outputEntry>
        <outputEntry id="outputEntry_5_2"><text>true</text></outputEntry>
      </rule>
      <rule id="rule_6">
        <description>Pre-2018 any other type -- ineligible</description>
        <inputEntry id="inputEntry_6_1"><text>&lt; 2018</text></inputEntry>
        <inputEntry id="inputEntry_6_2"><text>-</text></inputEntry>
        <outputEntry id="outputEntry_6_1"><text>50</text></outputEntry>
        <outputEntry id="outputEntry_6_2"><text>false</text></outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>
