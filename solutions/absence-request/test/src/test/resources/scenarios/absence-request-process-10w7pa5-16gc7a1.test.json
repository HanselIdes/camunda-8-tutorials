{
  "$schema": "https://camunda.com/json-schema/cpt-test-cases/8.9/schema.json",
  "testCases": [
    {
      "name": "happy path - absence approved",
      "description": "Employee requests absence, line manager approves. Absence is logged and employee is notified.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "variables": {
            "employeeName": "Alice Smith",
            "department": "sales",
            "policy": "flexibleTimeOff",
            "absenceStartDate": "2025-06-01",
            "absenceEndDate": "2025-06-05"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "RequestAbsenceTask" },
          "variables": {
            "employeeName": "Alice Smith",
            "department": "sales",
            "policy": "flexibleTimeOff",
            "absenceStartDate": "2025-06-01",
            "absenceEndDate": "2025-06-05"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "elementSelectors": [{ "elementId": "ApproveAbsenceTask" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "ApproveAbsenceTask" },
          "variables": { "approvalResult": "approved" }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "elementSelectors": [{ "elementId": "LogAbsenceTask" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "LogAbsenceTask" },
          "variables": { "absenceLogged": true }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "elementSelectors": [{ "elementId": "GetNotification" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "GetNotification" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "absence rejected - employee notified",
      "description": "Line manager rejects the absence request. Employee receives rejection notification.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "variables": {
            "employeeName": "Carol Jones",
            "department": "it",
            "policy": "sickness"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "RequestAbsenceTask" },
          "variables": { "employeeName": "Carol Jones" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "ApproveAbsenceTask" },
          "variables": { "approvalResult": "rejected", "rejectionReason": "Insufficient cover" }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "elementSelectors": [{ "elementId": "GetNotification" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "GetNotification" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "state": "IS_COMPLETED"
        }
      ]
    },
    {
      "name": "clarification requested then approved",
      "description": "Manager requests clarification, employee provides it, manager then approves.",
      "instructions": [
        {
          "type": "CREATE_PROCESS_INSTANCE",
          "processDefinitionSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "variables": {
            "employeeName": "Eve Worker",
            "department": "finance",
            "policy": "parentalLeave"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "RequestAbsenceTask" },
          "variables": { "employeeName": "Eve Worker" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "ApproveAbsenceTask" },
          "variables": {
            "approvalResult": "clarificationNeeded",
            "clarificationCommentLineManager": "Please provide exact dates"
          }
        },
        {
          "type": "ASSERT_ELEMENT_INSTANCES",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "elementSelectors": [{ "elementId": "ClarifyRequestTask" }],
          "state": "IS_ACTIVE"
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "ClarifyRequestTask" },
          "variables": {
            "clarificationCommentEmployee": "Dates are June 1-5",
            "absenceStartDate": "2025-06-01",
            "absenceEndDate": "2025-06-05"
          }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "ApproveAbsenceTask" },
          "variables": { "approvalResult": "approved" }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "LogAbsenceTask" },
          "variables": { "absenceLogged": true }
        },
        {
          "type": "COMPLETE_JOB",
          "jobSelector": { "elementId": "GetNotification" },
          "variables": {}
        },
        {
          "type": "ASSERT_PROCESS_INSTANCE",
          "processInstanceSelector": { "processDefinitionId": "absence-request-process-10w7pa5-16gc7a1" },
          "state": "IS_COMPLETED"
        }
      ]
    }
  ],
  "_integrationTestNotes": "This process has no external service connectors — all tasks are job-based user tasks (no zeebe:userTask) and one service task (GetLineManagerTask). Integration tests should verify: (1) GetLineManagerTask job worker correctly assigns a line manager based on the employee department variable; (2) end-to-end flow with a real Zeebe cluster."
}
