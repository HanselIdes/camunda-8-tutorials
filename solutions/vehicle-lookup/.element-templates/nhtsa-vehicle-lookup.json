{
  "$schema": "https://unpkg.com/@camunda/element-templates-json-schema/resources/schema.json",
  "name": "NHTSA Vehicle Lookup",
  "id": "io.camunda.demo:nhtsa-vehicle-lookup:1",
  "description": "Looks up a vehicle by VIN using the NHTSA public API. No authentication required. Stores the full API response as vehicleApiResponse for downstream processing.",
  "version": 1,
  "appliesTo": ["bpmn:ServiceTask"],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "input",
      "label": "Input"
    }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "io.camunda:http-json:1",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      }
    },
    {
      "type": "Hidden",
      "value": "GET",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      }
    },
    {
      "label": "VIN Lookup URL",
      "description": "Pre-filled with the NHTSA VIN decode endpoint. References the 'vin' process variable. Adjust the expression if your variable is named differently.",
      "type": "String",
      "feel": "optional",
      "value": "= \"https://api.nhtsa.gov/vehicles/decodevin/\" + vin",
      "group": "input",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "constraints": {
        "notEmpty": true
      }
    },
    {
      "type": "Hidden",
      "value": "vehicleApiResponse",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultVariable"
      }
    }
  ]
}
