{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "NHTSA Vehicle Lookup",
  "id": "io.camunda.demo:nhtsa-vehicle-lookup:1",
  "version": 1,
  "description": "Looks up a vehicle by VIN using the NHTSA public API. No authentication required. Reads `vin` from the process and stores the full HTTP response as `vehicleApiResponse`.",
  "documentationRef": "https://vpic.nhtsa.dot.gov/api/",
  "icon": {
    "contents": "data:image/png;base64,"
  },
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "appliesTo": [
    "bpmn:Task"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    {
      "id": "endpoint",
      "label": "HTTP endpoint"
    },
    {
      "id": "output",
      "label": "Response mapping"
    },
    {
      "id": "errors",
      "label": "Error handling"
    }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "io.camunda:http-json:1",
      "binding": {
        "type": "zeebe:taskDefinition",
        "property": "type"
      }
    },
    {
      "type": "Hidden",
      "value": "noAuth",
      "binding": {
        "type": "zeebe:input",
        "name": "authentication.type"
      }
    },
    {
      "type": "Hidden",
      "value": "get",
      "binding": {
        "type": "zeebe:input",
        "name": "method"
      }
    },
    {
      "label": "VIN lookup URL",
      "description": "NHTSA VIN decode endpoint. Reads `vin` from the process (17-character Vehicle Identification Number).",
      "group": "endpoint",
      "type": "String",
      "feel": "optional",
      "value": "= \"https://vpic.nhtsa.dot.gov/api/vehicles/decodevin/\" + vin + \"?format=json\"",
      "binding": {
        "type": "zeebe:input",
        "name": "url"
      },
      "constraints": {
        "notEmpty": true,
        "pattern": {
          "value": "^(=|(https?://|secrets\\..+|\\{\\{secrets\\..+\\}\\}).*$)",
          "message": "Must be a http(s) URL"
        }
      },
      "editable": false
    },
    {
      "type": "Hidden",
      "binding": {
        "type": "zeebe:input",
        "name": "queryParameters"
      }
    },
    {
      "type": "Hidden",
      "binding": {
        "type": "zeebe:input",
        "name": "headers"
      }
    },
    {
      "type": "Hidden",
      "value": "20",
      "binding": {
        "type": "zeebe:input",
        "name": "connectionTimeoutInSeconds"
      }
    },
    {
      "label": "Result variable",
      "description": "Variable that stores the full HTTP response. Response contains `body.Results` (array of Variable/Value pairs), `headers`, and `status`.",
      "group": "output",
      "type": "String",
      "value": "vehicleApiResponse",
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultVariable"
      },
      "editable": false
    },
    {
      "label": "Result expression",
      "description": "Optional FEEL expression to map the response into process variables. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/#result-expression\" target=\"_blank\">documentation</a>.",
      "group": "output",
      "type": "Text",
      "feel": "required",
      "optional": true,
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "resultExpression"
      }
    },
    {
      "label": "Error expression",
      "description": "Optional FEEL expression to handle errors. Details in the <a href=\"https://docs.camunda.io/docs/components/connectors/use-connectors/#bpmn-errors\" target=\"_blank\">documentation</a>.",
      "group": "errors",
      "type": "Text",
      "feel": "required",
      "optional": true,
      "binding": {
        "type": "zeebe:taskHeader",
        "key": "errorExpression"
      }
    }
  ],
  "engines": {
    "camunda": "^8.2"
  }
}
